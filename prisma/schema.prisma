// Scout Vision - Production Database Schema
// Multi-sport AI recruiting intelligence platform
// SOC2-ready, acquisition-grade relational schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── IDENTITY & ACCESS ──────────────────────────────────────────────

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  name         String?
  avatarUrl    String?
  password     String
  role         Role             @relation(fields: [roleId], references: [id])
  roleId       String
  program      Program?         @relation(fields: [programId], references: [id])
  programId    String?
  isActive     Boolean          @default(true)
  lastLoginAt  DateTime?
  mfaEnabled   Boolean          @default(false)
  mfaSecret    String?
  preferences  Json?            // UI preferences, notification settings
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  notes        Note[]
  evaluations  Evaluation[]
  complianceEvents ComplianceEvent[]
  auditLogs    AuditLog[]
  contactLogs  ContactLog[]
  emailsSent   Email[]
  uploads      Upload[]
  savedSearches SavedSearch[]
  notifications Notification[]
  sessions     Session[]

  @@index([email])
  @@index([programId])
}

model Session {
  id           String    @id @default(uuid())
  token        String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique  // Admin, Coach, Assistant, Analyst, Scout, Viewer
  permissions Json?   // Granular permission flags
  users       User[]
}

// ─── ORGANIZATION ───────────────────────────────────────────────────

model Program {
  id             String           @id @default(uuid())
  name           String
  sport          String           @default("Football")
  division       String           // D2, D3, NAIA, D1-FCS
  conference     String?
  logoUrl        String?
  state          String?
  primaryColor   String?          // Brand color
  secondaryColor String?
  website        String?
  subscriptionTier String         @default("starter") // starter, growth, elite, enterprise
  stripeCustomerId String?        @unique
  stripeSubscriptionId String?
  maxUsers       Int              @default(5)
  maxProspects   Int              @default(200)
  maxStorage     Int              @default(10240) // MB
  features       Json?            // Feature flags per tier
  users          User[]
  prospects      Prospect[]
  stages         RecruitingStage[]
  pipelineMetrics PipelineMetric[]
  complianceEvents ComplianceEvent[]
  recruitingPeriods RecruitingPeriod[]
  uploads        Upload[]
  boardTemplates BoardTemplate[]
  notifications  Notification[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([division])
  @@index([sport])
}

// ─── PROSPECTS & RECRUITING ─────────────────────────────────────────

model Prospect {
  id              String           @id @default(uuid())
  firstName       String
  lastName        String
  bio             String?
  email           String?
  phone           String?
  imageUrl        String?
  position        String?
  secondaryPosition String?
  height          String?
  weight          Int?
  highSchool      String?
  clubTeam        String?
  city            String?
  state           String?
  zipCode         String?
  hudlUrl         String?
  twitterUrl      String?
  instagramUrl    String?
  maxPrepsUrl     String?
  rivalUrl        String?
  tags            String[]         @default([])
  commitmentScore Float?           // AI-generated likelihood 0-100
  classYear       Int?             // e.g. 2027
  status          String           @default("active") // active, archived, committed, enrolled, decommitted
  tier            String?          // priority, target, sleeper, depth

  stats           ProspectStats?
  academics       ProspectAcademics?
  videos          Video[]
  notes           Note[]
  evaluations     Evaluation[]
  emails          Email[]
  visits          Visit[]
  contactLogs     ContactLog[]
  aiReports       AIReport[]
  aiAnalyses      AIAnalysis[]

  program         Program?         @relation(fields: [programId], references: [id], onDelete: SetNull)
  programId       String?
  stage           RecruitingStage? @relation(fields: [stageId], references: [id])
  stageId         String?
  stageOrder      Int              @default(0)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([programId])
  @@index([stageId])
  @@index([lastName, firstName])
  @@index([state])
  @@index([position])
  @@index([classYear])
  @@index([status])
  @@index([tier])
}

model ProspectStats {
  id             String    @id @default(uuid())
  fortyYard      Float?
  shuttle        Float?
  vertical       Float?
  bench          Int?
  squat          Int?
  broad          Float?
  sportMetrics   Json?
  prospect       Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId     String    @unique
  updatedAt      DateTime  @updatedAt
}

model ProspectAcademics {
  id             String    @id @default(uuid())
  gpa            Float?
  satScore       Int?
  actScore       Int?
  school         String?
  gradYear       Int?
  intendedMajor  String?
  ncaaEligible   Boolean?
  coreGpa        Float?
  prospect       Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId     String    @unique
  updatedAt      DateTime  @updatedAt
}

model RecruitingStage {
  id          String     @id @default(uuid())
  name        String
  order       Int
  color       String     @default("#6B7280")
  program     Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId   String
  prospects   Prospect[]

  @@unique([programId, order])
  @@index([programId])
}

// ─── COMMUNICATION ──────────────────────────────────────────────────

model Email {
  id           String    @id @default(uuid())
  to           String
  from         String
  subject      String
  body         String
  templateId   String?
  sentAt       DateTime  @default(now())
  openedAt     DateTime?
  clickedAt    DateTime?
  opened       Boolean   @default(false)
  clicked      Boolean   @default(false)
  bounced      Boolean   @default(false)

  prospect     Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  prospectId   String?
  sender       User?     @relation(fields: [senderId], references: [id])
  senderId     String?

  @@index([prospectId])
  @@index([sentAt])
}

model ContactLog {
  id           String    @id @default(uuid())
  type         String    // call, text, in-person, social, mail
  direction    String    @default("outbound")
  summary      String?
  duration     Int?
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId   String
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  occurredAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([prospectId])
  @@index([occurredAt])
}

// ─── EVALUATIONS & NOTES ────────────────────────────────────────────

model Note {
  id           String    @id @default(uuid())
  content      String
  isPinned     Boolean   @default(false)
  author       User?     @relation(fields: [authorId], references: [id])
  authorId     String?
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([prospectId])
}

model Evaluation {
  id           String    @id @default(uuid())
  overallScore Int
  athleticism  Int?
  academics    Int?
  character    Int?
  skillLevel   Int?
  comment      String?
  author       User?     @relation(fields: [authorId], references: [id])
  authorId     String?
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId   String
  createdAt    DateTime  @default(now())

  @@index([prospectId])
}

// ─── COMPLIANCE ─────────────────────────────────────────────────────

model ComplianceEvent {
  id           String    @id @default(uuid())
  type         String
  title        String?
  details      String?
  severity     String    @default("info")
  resolved     Boolean   @default(false)

  program      Program?  @relation(fields: [programId], references: [id])
  programId    String?
  user         User?     @relation(fields: [userId], references: [id])
  userId       String?
  createdAt    DateTime  @default(now())

  @@index([programId])
  @@index([type])
  @@index([createdAt])
}

model RecruitingPeriod {
  id           String    @id @default(uuid())
  type         String    // contact, quiet, dead, evaluation
  sport        String    @default("Football")
  startDate    DateTime
  endDate      DateTime
  description  String?
  program      Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId    String

  @@index([programId])
  @@index([startDate, endDate])
}

model Visit {
  id           String    @id @default(uuid())
  type         String    @default("unofficial")
  date         DateTime
  location     String?
  notes        String?
  status       String    @default("scheduled")
  prospect     Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  prospectId   String
  createdAt    DateTime  @default(now())

  @@index([prospectId])
  @@index([date])
}

// ─── VIDEO SCOUTING ─────────────────────────────────────────────────

model Video {
  id           String      @id @default(uuid())
  title        String?
  url          String
  type         String?     // game, practice, combine, highlight
  sourceType   String      @default("link") // link, upload, hudl, youtube
  storagePath  String?
  thumbnailUrl String?
  duration     Float?
  fileSize     Int?        // bytes
  resolution   String?     // 1080p, 720p, 4K
  fps          Float?
  status       String      @default("ready") // uploading, processing, ready, analyzed, failed
  aiTags       Json?
  aiMetrics    Json?
  sport        String      @default("football")

  prospect     Prospect?   @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  prospectId   String?
  clips        VideoClip[]
  analyses     AIAnalysis[]
  upload       Upload?     @relation(fields: [uploadId], references: [id])
  uploadId     String?
  createdAt    DateTime    @default(now())

  @@index([prospectId])
  @@index([status])
  @@index([sport])
}

model VideoClip {
  id           String    @id @default(uuid())
  title        String?
  video        Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  videoId      String
  startTime    Float
  endTime      Float
  rating       Int?
  tags         String[]  @default([])
  notes        String?
  shareToken   String?   @unique
  thumbnailUrl String?
  createdAt    DateTime  @default(now())

  @@index([videoId])
  @@index([shareToken])
}

// ─── AI ANALYSIS ────────────────────────────────────────────────────

model AIAnalysis {
  id              String    @id @default(uuid())
  videoId         String
  video           Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  prospectId      String?
  prospect        Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  sport           String    @default("football")
  status          String    @default("queued") // queued, processing, completed, failed
  progress        Int       @default(0)
  currentStage    String?
  processingTimeMs Int?
  framesProcessed Int?

  // Results stored as JSON for flexibility
  playerDetections Json?   // Array of detected player summaries
  highlights       Json?   // Array of highlight moments
  plays            Json?   // Array of classified plays
  biomechanics     Json?   // Biomechanics analysis results
  sportMetrics     Json?   // Sport-specific computed metrics
  overallGrade     String?
  aiInsights       Json?   // Array of insight strings

  error           String?
  modelVersions   Json?    // Versions of models used
  gpuDeviceId     Int?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([videoId])
  @@index([prospectId])
  @@index([status])
  @@index([createdAt])
}

model AIReport {
  id                  String    @id @default(uuid())
  prospectId          String
  prospect            Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  sport               String    @default("football")
  type                String    @default("scouting") // scouting, game_summary, comparison, team_fit
  overallGrade        String?
  summary             String?
  strengths           Json?     // string[]
  weaknesses          Json?     // string[]
  projections         Json?     // performance projections
  comparisons         Json?     // player comparisons
  recommendation      String?
  fitScore            Float?
  recruitingPriority  String?   // must-have, high, medium, low, monitor
  llmProvider         String?   // openai, anthropic
  llmModel            String?   // gpt-4, claude-3-opus, etc.
  promptTokens        Int?
  completionTokens    Int?
  createdAt           DateTime  @default(now())

  @@index([prospectId])
  @@index([type])
  @@index([createdAt])
}

// ─── UPLOAD SYSTEM ──────────────────────────────────────────────────

model Upload {
  id           String    @id @default(uuid())
  fileName     String
  originalName String
  mimeType     String
  fileSize     Int       // bytes
  storagePath  String
  storageUrl   String?
  status       String    @default("uploading") // uploading, processing, ready, failed
  progress     Int       @default(0)
  category     String    @default("video") // video, document, image, csv
  metadata     Json?     // dimensions, duration, codec, etc.
  checksum     String?   // SHA-256

  userId       String
  user         User      @relation(fields: [userId], references: [id])
  programId    String?
  program      Program?  @relation(fields: [programId], references: [id])
  videos       Video[]
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  @@index([userId])
  @@index([programId])
  @@index([status])
  @@index([category])
}

// ─── SAVED SEARCHES & BOARD TEMPLATES ───────────────────────────────

model SavedSearch {
  id         String   @id @default(uuid())
  name       String
  query      String   // Natural language query
  filters    Json?    // Parsed filter object
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isPinned   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model BoardTemplate {
  id         String   @id @default(uuid())
  name       String
  stages     Json     // Array of { name, color, order }
  isDefault  Boolean  @default(false)
  programId  String
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([programId])
}

// ─── NOTIFICATIONS ──────────────────────────────────────────────────

model Notification {
  id         String    @id @default(uuid())
  type       String    // analysis_complete, report_ready, compliance_alert, visit_reminder, stage_change
  title      String
  message    String?
  link       String?   // Deep link into the app
  read       Boolean   @default(false)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId  String?
  program    Program?  @relation(fields: [programId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

// ─── ANALYTICS & PIPELINE ───────────────────────────────────────────

model PipelineMetric {
  id           String    @id @default(uuid())
  type         String
  dimension    String?
  value        Float
  metadata     Json?
  program      Program?  @relation(fields: [programId], references: [id])
  programId    String?
  period       String?
  createdAt    DateTime  @default(now())

  @@index([programId])
  @@index([type])
}

// ─── AUDIT & SECURITY ───────────────────────────────────────────────

model AuditLog {
  id           String    @id @default(uuid())
  action       String    // create, update, delete, login, logout, export, ai_analysis, report_generated
  entity       String?   // prospect, video, evaluation, etc.
  entityId     String?
  details      String?
  oldValue     Json?     // Previous state for update tracking
  newValue     Json?     // New state for update tracking
  ipAddress    String?
  userAgent    String?
  user         User?     @relation(fields: [userId], references: [id])
  userId       String?
  duration     Int?      // Operation duration in ms
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}
